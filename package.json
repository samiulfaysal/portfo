{
  "name": "c_portfoloio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
"scripts": {
  "dev": "next dev",
  "postinstall": "prisma generate",
  "build": "prisma migrate deploy && next build",
  "start": "next start",
  "lint": "eslint",
  "db:init": "node --loader ts-node/esm src/lib/init-db.ts",
  "db:migrate": "prisma migrate dev",
  "db:migrate:deploy": "prisma migrate deploy",
  "db:generate": "prisma generate",
  "db:reset": "prisma migrate reset --force",
  "db:seed": "node --loader ts-node/esm src/lib/init-db.ts"
},
  "dependencies": {
